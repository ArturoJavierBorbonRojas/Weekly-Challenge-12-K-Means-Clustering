import numpy as np
import matplotlib.pyplot as plt

# Weekly Challenge 12: K-Means Clustering
# Author: Ing. Arturo Javier Borbon Rojas

# 1 We generate synthetic data without label in 3 clusters:
cluster1= np.random.randn(50,2) + np.array([2,2])
cluster2= np.random.randn(50,2) + np.array([8,3])
cluster3= np.random.randn(50,2) + np.array([5,8])

# 1.1 We print our results:
print(f"Our synthetic are:")
print(f"Cluster 1:{cluster1} ")
print(f"Cluster 2:{cluster2} ")
print(f"Cluster 3:{cluster3} ")
print("-"*20)

# 1.2 We combine all points into a single dataset in X
X= np.vstack((cluster1, cluster2, cluster3))

# 2 We initialize our parameters:

# 2.1 K number of clusters we want to find: 
K=3

# 2.2 Max number of iterations:
max_iters= 10

# 2.3 Randomly initialize the starting positions of our K centroids
initial_indices= np.random.choice(len(X), K, replace=False)
centroids= X[initial_indices]

# 2.4 Listo to kepp track of centroid movement for visualization
centroid_history = [centroids.copy()]

# 2.5 Print parameters:
print(f"""Our parameters are:
      K={K}
      MAX iterations={max_iters}
      """)


# 3 K-Means training loop
for i in range(max_iters):
    #3.1 We assign each point to the nearest centroid
    # Calculate Eucidean distance from each point to each centroid
    distances= np.linalg.norm(X[:, np.newaxis]- centroids, axis=2)
    labels= np.argmin(distances, axis=1)

    # 3.2 Update centroids by calculating the mean of the assigned points
    new_centroids= np.array([X[labels ==k].mean(axis=0) for k in range(K)])

    # Check for convergence (if centroids stop moving, break early)
    if np.all(centroids == new_centroids):
        print(f"✅ Converged perfectly at iteration {i+1}!")
        break

    centroids = new_centroids
    centroid_history.append(centroids.copy())
    print(f"🔄 Iteration {i+1} completed. Centroids updated.")


print("-"*45)

# 4 Matplotlib visualization
plt.figure(figsize=(8,6))
colors = ["#FF9999", "#99CCFF", "#99FF99"]
dark_colors= ["red", "blue", "green"]

# Plot the clustered data points
for k in range(K):
    cluster_points = X[labels == k]
    plt.scatter(cluster_points[:, 0], cluster_points[:, 1], color=colors[k], label=f'Cluster {k+1}', alpha=0.7, edgecolors='w')

# Plot the path of the centroids (how they learned)
centroid_history = np.array(centroid_history)
for k in range(K):
    # Plot the trajectory line
    plt.plot(centroid_history[:, k, 0], centroid_history[:, k, 1], color='black', linestyle='--', alpha=0.5)
    # Plot the final centroid position as a large star
    plt.scatter(centroids[k, 0], centroids[k, 1], color=dark_colors[k], marker='*', s=300, edgecolor='black', zorder=10)
    # Plot the starting position as a small X
    plt.scatter(centroid_history[0, k, 0], centroid_history[0, k, 1], color='black', marker='x', s=100, zorder=10)

plt.title("K-Means Clustering from Scratch (Centroid Trajectories)")
plt.xlabel("Feature X")
plt.ylabel("Feature Y")
plt.legend()
plt.grid(True, alpha=0.3)
plt.show()